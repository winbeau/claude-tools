# DeepSeek (OpenAI-compatible). Used by enrichers/quota_extractor.py
DEEPSEEK_API_KEY=sk-replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Contact address embedded in User-Agent (good crawling etiquette)
CLAW_CONTACT_EMAIL=you@example.com

# SQLite path (defaults to data/claw.db)
CLAW_DB_PATH=data/claw.db

# Rate limit (requests/sec/domain)
CLAW_RPS=0.5

# Snapshot directory
CLAW_SNAPSHOT_DIR=data/snapshots

# Playwright session dir
CLAW_SESSION_DIR=data/sessions
